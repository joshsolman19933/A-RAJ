// ============================================================
// A RAJ - Prisma Schema
// Sprint 1.2: Core models (User, Hive, Chamber)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- User (Authentication) ---

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  premiumTier  String   @default("FREE") @map("premium_tier") // FREE | PREMIUM
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  hives         Hive[]
  refreshTokens RefreshToken[]
  clanMember    ClanMember?
  sentTrades    ClanTrade[]    @relation("SentTrades")
  receivedTrades ClanTrade[]   @relation("ReceivedTrades")
  transactions  Transaction[]

  @@map("users")
}

// --- Hive (Kaptár) ---

model Hive {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  q           Int      @default(0)
  r           Int      @default(0)
  biomass     Float    @default(500)
  water       Float    @default(300)
  heat        Float    @default(100)
  dnaNectar   Float    @default(0) @map("dna_nectar")
  lastUpdated DateTime @default(now()) @map("last_updated")
  createdAt   DateTime @default(now()) @map("created_at")

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  chambers     Chamber[]
  unitBatches  UnitBatch[]
  mutations    Mutation[]
  movements    Movement[]
  mapHexes     MapHex[]
  queenTraining QueenTraining?
  cosmetic      HiveCosmetic?

  @@index([userId])
  @@index([q, r])
  @@map("hives")
}

// --- Chamber (Kamra / Épület) ---

model Chamber {
  id        String   @id @default(uuid())
  hiveId    String   @map("hive_id")
  type      String   // QUEEN, HATCHERY, DIGESTIVE_PIT, etc.
  level     Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  hive Hive @relation(fields: [hiveId], references: [id], onDelete: Cascade)

  @@index([hiveId])
  @@map("chambers")
}

// --- UnitBatch (Egység csoport a keltetőből) ---

model UnitBatch {
  id        String   @id @default(uuid())
  hiveId    String   @map("hive_id")
  unitType  String   @map("unit_type")
  count     Int
  hatchedAt DateTime @map("hatched_at")
  lifespan  Int      // lifespan in hours (snapshot from UNIT_STATS at hatch time)

  hive Hive @relation(fields: [hiveId], references: [id], onDelete: Cascade)

  @@index([hiveId])
  @@map("unit_batches")
}

// --- Mutation (Kutatott mutáció) ---

model Mutation {
  id           String   @id @default(uuid())
  hiveId       String   @map("hive_id")
  mutationType String   @map("mutation_type")
  level        Int      @default(1)

  hive Hive @relation(fields: [hiveId], references: [id], onDelete: Cascade)

  @@unique([hiveId, mutationType])
  @@index([hiveId])
  @@map("mutations")
}

// --- MapHex (Térkép hexa mező) ---

model MapHex {
  q      Int
  r      Int
  type   String   @default("EMPTY") // EMPTY, MOUNTAIN, LAKE, HIVE, PVE_NEST
  hiveId String?  @map("hive_id")

  hive Hive? @relation(fields: [hiveId], references: [id], onDelete: SetNull)

  @@index([hiveId])

  @@id([q, r])
  @@map("map_hexes")
}

// --- Movement (Támadás / Mozgás) ---

model Movement {
  id          String   @id @default(uuid())
  fromHiveId  String   @map("from_hive_id")
  attackType  String   @map("attack_type") // RAID, SIEGE
  targetQ     Int      @map("target_q")
  targetR     Int      @map("target_r")
  sentAt      DateTime @default(now()) @map("sent_at")
  arriveAt    DateTime @map("arrive_at")
  units       Json     @default("[]") // UnitBatchBrief[]: [{unitType, count}, ...]

  fromHive Hive @relation(fields: [fromHiveId], references: [id], onDelete: Cascade)

  @@index([fromHiveId])
  @@index([targetQ, targetR])
  @@map("movements")
}

// --- Clan (Boly / Klán) ---

model Clan {
  id          String   @id @default(uuid())
  name        String   @unique
  description String   @default("")
  colorHex    String   @default("#cc3333") @map("color_hex")
  level       Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")

  members             ClanMember[]
  outgoingDiplomacies ClanDiplomacy[] @relation("ClanDiplomacies")
  incomingDiplomacies ClanDiplomacy[] @relation("TargetClanDiplomacies")
  trades              ClanTrade[]
  trails              FeromonTrail[]

  @@map("clans")
}

// --- ClanMember (Klán tag) ---

model ClanMember {
  id       String   @id @default(uuid())
  clanId   String   @map("clan_id")
  userId   String   @map("user_id")
  role     String   @default("MEMBER") // LEADER, OFFICER, MEMBER
  joinedAt DateTime @default(now()) @map("joined_at")

  clan Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([clanId])
  @@map("clan_members")
}

// --- ClanDiplomacy (Klánok közötti diplomácia) ---

model ClanDiplomacy {
  id            String   @id @default(uuid())
  clanId        String   @map("clan_id")
  targetClanId  String   @map("target_clan_id")
  status        String   @default("NEUTRAL") // ALLY, ENEMY, NAP, NEUTRAL
  setAt         DateTime @default(now()) @map("set_at")

  clan       Clan @relation("ClanDiplomacies", fields: [clanId], references: [id], onDelete: Cascade)
  targetClan Clan @relation("TargetClanDiplomacies", fields: [targetClanId], references: [id], onDelete: Cascade)

  @@unique([clanId, targetClanId])
  @@index([clanId])
  @@index([targetClanId])
  @@map("clan_diplomacies")
}

// --- ClanTrade (Belső feromon piac / erőforrás csere) ---

model ClanTrade {
  id           String   @id @default(uuid())
  clanId       String   @map("clan_id")
  fromUserId   String   @map("from_user_id")
  toUserId     String   @map("to_user_id")
  resourceType String   @map("resource_type") // BIOMASS, WATER, DNA_NECTAR
  amount       Float
  createdAt    DateTime @default(now()) @map("created_at")

  clan     Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)
  fromUser User @relation("SentTrades", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("ReceivedTrades", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([clanId])
  @@index([fromUserId])
  @@index([toUserId])
  @@map("clan_trades")
}

// --- Refresh Token (for JWT refresh) ---

// --- FeromonTrail (Feromon-nyom a térképen) ---

model FeromonTrail {
  id        String   @id @default(uuid())
  clanId    String   @map("clan_id")
  type      String   @default("ATTACK") // ATTACK, DEFEND
  path      Json     @default("[]") // HexCoord[]: [{q, r}, ...]
  expiresAt DateTime @map("expires_at")
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  clan Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)

  @@index([clanId])
  @@map("feromon_trails")
}

// --- QueenTraining (Királynő képzés) ---

model QueenTraining {
  id          String   @id @default(uuid())
  hiveId      String   @unique @map("hive_id")
  status      String   @default("TRAINING") // TRAINING, READY, CANCELLED
  startedAt   DateTime @default(now()) @map("started_at")
  completesAt DateTime @map("completes_at")
  completedAt DateTime? @map("completed_at")
  jobId       String?  @map("job_id")

  hive Hive @relation(fields: [hiveId], references: [id], onDelete: Cascade)

  @@index([hiveId])
  @@map("queen_training")
}

// --- PveNest (PvE fészek — nehézség & respawn) ---

model PveNest {
  id         String    @id @default(uuid())
  q          Int
  r          Int
  tier       String    @default("EASY") // EASY, MEDIUM, HARD
  defeatedAt DateTime? @map("defeated_at")
  respawnAt  DateTime? @map("respawn_at")
  jobId      String?   @map("job_id")

  @@unique([q, r])
  @@index([q, r])
  @@map("pve_nests")
}

// --- Transaction (Monetizáció — vásárlási előzmények) ---

model Transaction {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  type        String   @default("PREMIUM_PURCHASE") // PREMIUM_PURCHASE, COSMETIC_PURCHASE, ZSELE_PACK
  amount      Float    @default(0)
  zseleSpent  Int      @default(0) @map("zsele_spent")
  description String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("transactions")
}

// --- HiveCosmetic (Kozmetikai skinek kaptáranként) ---

model HiveCosmetic {
  hiveId   String @id @map("hive_id")
  skinType String @default("DEFAULT") @map("skin_type") // DEFAULT, CRIMSON, OBSIDIAN, VENOM_GREEN, HIVE_GOLD, SPECTRAL

  hive Hive @relation(fields: [hiveId], references: [id], onDelete: Cascade)

  @@map("hive_cosmetics")
}

// --- Refresh Token (for JWT refresh) ---

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}
