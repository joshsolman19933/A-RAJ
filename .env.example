# A RAJ Backend Environment Variables
# Copy this to .env and fill in values

# Database
DATABASE_URL=postgresql://araj:araj_dev_password@localhost:5432/araj?schema=public
DB_PASSWORD=araj_dev_password
DB_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=araj-dev-secret-change-in-production

# App
PORT=3000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
